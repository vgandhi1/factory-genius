# Factory Genius — environment template
# Copy to .env and fill in values. Never commit .env.

# --- MQTT (docker compose Mosquitto) ---
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC_PATTERN=conveyance/+/anomaly

# --- RAG knowledge base (path relative to repo root or absolute) ---
KNOWLEDGE_DIR=data/knowledge

# --- Optional OpenAI-compatible LLM (leave empty for template-only diagnosis) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- CORS (comma-separated origins for Vite dev server) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Audio upload limit (bytes; default 25 MiB) ---
MAX_AUDIO_UPLOAD_BYTES=26214400
